<Page
    x:Class="Nokia_Chat.MessagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nokia_Chat"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.TopAppBar>
        <CommandBar>
            <AppBarButton x:ConnectionId='1' Label="刷新"                             Icon="Sync"/>
        </CommandBar>
    </Page.TopAppBar>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ConversationTitleTextBlock" Grid.Row="0" Margin="0,0,0,8" Style="{ThemeResource HeaderTextBlockStyle}"/>

        <ListView x:Name="MessagesListView" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="8,6">
                        <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TimeText}" Opacity="0.6" FontSize="20"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SendTextBox" PlaceholderText="说点什么..." AcceptsReturn="False"/>
            <Button x:ConnectionId='2' Grid.Column="1" Content="发送"                          Margin="12,0,0,0"/>
        </Grid>
    </Grid>
</Page>

